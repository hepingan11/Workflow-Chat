APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
CONFIG_DIR=.workflow-chat

# LLM
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=

# Workflow
DEFAULT_WORKFLOW_PROVIDER=dify
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_OPERATOR_PUBLISH_USER=workflow-chat-operator

# Web
API_BASE_URL=http://127.0.0.1:8000

# Runtime
WORKSPACE_ROOT=.
APPROVAL_REQUIRED_FOR_MEDIUM_RISK=true
